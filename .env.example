# Variáveis de Ambiente — Exemplo
# Copie para .env.local (nunca commitar o arquivo preenchido)

# Banco de Dados (Docker Compose local)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=simpleapi

# Aplicação
API_PORT=3000
NODE_ENV=development

# AWS — Configuração regional (sem credenciais estáticas!)
# Em produção: usar OIDC ou IAM Role via instance profile / ECS task role
# Em desenvolvimento local: usar 'aws configure' com SSO ou perfil nomeado
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=468142523818

# Terraform
TF_VAR_project_name=simple-api
TF_VAR_container_cpu=256
TF_VAR_container_memory=512
TF_VAR_desired_count=2
TF_VAR_domain_name=api.exemplo.com
TF_VAR_alert_email=ops@exemplo.com
